{
  "name": "easyclaw",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev": "bash scripts/fix-vendor-hardlinks.sh && turbo run dev",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "postinstall": "bash scripts/fix-vendor-hardlinks.sh && bash scripts/rebuild-native.sh",
    "verify-proxy": "node scripts/verify-proxy-domains.mjs",
    "check:ext-externals": "node scripts/check-extension-externals.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "oxfmt": "0.28.0",
    "oxlint": "^1.43.0",
    "turbo": "^2.4.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.6.2",
  "dependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.0-rc.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}