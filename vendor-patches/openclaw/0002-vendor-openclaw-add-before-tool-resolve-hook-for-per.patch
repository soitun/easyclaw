+// before_tool_resolve hook — allows plugins to filter the tool list before session creation
+export type PluginHookBeforeToolResolveEvent = {
+  /** Tool names available for this session. */
+  tools: string[];
+};
+
+export type PluginHookBeforeToolResolveResult = {
+  /** Filtered tool names. Tools not in this list are removed from the session. */
+  tools?: string[];
+};
+
 // before_tool_call hook
 export type PluginHookBeforeToolCallEvent = {
   toolName: string;
@@ -982,6 +995,10 @@ export type PluginHookHandlerMap = {
