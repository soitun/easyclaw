     const toolsEnabled = supportsModelTools(params.model);
-    const tools = sanitizeToolsForGoogle({
+    let tools = sanitizeToolsForGoogle({
       tools: toolsEnabled ? toolsRaw : [],
       provider: params.provider,
     });
+
+    // before_tool_resolve hook: filter tools BEFORE system prompt is built (ADR-031).
+    // This ensures both the tool list AND the system prompt only include selected tools.
+    {
+      const earlyHookRunner = getGlobalHookRunner();
+      if (earlyHookRunner?.hasHooks("before_tool_resolve")) {
+        const toolNames = tools.map((t: { name: string }) => t.name);
+        const hookResult = await earlyHookRunner.runBeforeToolResolve(
+          { tools: toolNames },
