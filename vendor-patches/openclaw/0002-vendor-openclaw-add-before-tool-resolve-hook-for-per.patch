+    ctx: PluginHookAgentContext,
+  ) => Promise<PluginHookBeforeToolResolveResult | void> | PluginHookBeforeToolResolveResult | void;
   before_tool_call: (
     event: PluginHookBeforeToolCallEvent,
     ctx: PluginHookToolContext,
@@ -1044,7 +1061,10 @@ export type PluginHookHandlerMap = {
   before_browser_action: (
