From 6c87c06f9cb323abbb5ffe6987378017eebc9667 Mon Sep 17 00:00:00 2001
From: Gaoyang Zhang <younglobalization@gmail.com>
Date: Thu, 19 Mar 2026 00:37:51 -0700
Subject: [PATCH] vendor(openclaw): add before_tool_resolve hook for
 per-session tool filtering

Why:
- RivonClaw's four-layer capability model (ADR-031) requires per-session
  tool visibility control. Tools not in effectiveTools should not appear
  in the LLM's tool list OR system prompt.
- The hook fires in attempt.ts and compact.ts BEFORE buildEmbeddedSystemPrompt()
  so that both the tool list AND the system prompt only include selected tools.
- splitSdkTools() remains unchanged (sync, no hook logic). The hook is called
  directly in the caller where the tools variable is defined.

Removal:
- Can be dropped if OpenClaw adds native per-session tool filtering via
  config or a built-in hook. No upstream PR exists yet.

Tests:
- extensions/rivonclaw-capability-manager/src/index.test.ts
- apps/desktop/e2e/tool-visibility.spec.ts
---
 src/agents/pi-embedded-runner/compact.ts     | 20 +++++++++++++++-
 src/agents/pi-embedded-runner/run/attempt.ts | 23 ++++++++++++++++---
 src/plugins/hooks.ts                         | 24 ++++++++++++++++++++
 src/plugins/types.ts                         | 22 +++++++++++++++++-
 4 files changed, 84 insertions(+), 5 deletions(-)

diff --git a/src/agents/pi-embedded-runner/compact.ts b/src/agents/pi-embedded-runner/compact.ts
index 8c490e113d..dac68d5e36 100644
--- a/src/agents/pi-embedded-runner/compact.ts
+++ b/src/agents/pi-embedded-runner/compact.ts
@@ -555,7 +555,7 @@ export async function compactEmbeddedPiSessionDirect(
       modelContextWindowTokens: ctxInfo.tokens,
       modelAuthMode: resolveModelAuthMode(model.provider, params.config),
     });
-    const tools = sanitizeToolsForGoogle({
+    let tools = sanitizeToolsForGoogle({
       tools: supportsModelTools(model) ? toolsRaw : [],
       provider,
     });
@@ -656,6 +656,23 @@ export async function compactEmbeddedPiSessionDirect(
     });
     const ttsHint = params.config ? buildTtsSystemPromptHint(params.config) : undefined;
     const ownerDisplay = resolveOwnerDisplaySetting(params.config);
+
+    // before_tool_resolve hook: filter tools BEFORE system prompt is built (ADR-031).
+    {
+      const earlyHookRunner = getGlobalHookRunner();
+      if (earlyHookRunner?.hasHooks("before_tool_resolve")) {
+        const toolNames = tools.map((t: { name: string }) => t.name);
+        const hookResult = await earlyHookRunner.runBeforeToolResolve(
+          { tools: toolNames },
+          { agentId: sessionAgentId, sessionKey: params.sessionKey?.trim() || params.sessionId },
+        );
+        if (hookResult?.tools) {
+          const allowed = new Set(hookResult.tools);
+          tools = tools.filter((t: { name: string }) => allowed.has(t.name));
+        }
+      }
+    }
+
     const appendPrompt = buildEmbeddedSystemPrompt({
       workspaceDir: effectiveWorkspace,
       defaultThinkLevel: params.thinkLevel,
@@ -738,6 +755,7 @@ export async function compactEmbeddedPiSessionDirect(
         await resourceLoader.reload();
       }
 
+      // Tools already filtered by before_tool_resolve hook above (before system prompt build).
       const { builtInTools, customTools } = splitSdkTools({
         tools,
         sandboxEnabled: !!sandbox?.enabled,
