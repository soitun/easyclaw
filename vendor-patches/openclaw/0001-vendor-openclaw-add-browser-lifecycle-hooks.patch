+  ): Promise<void> {
+    await runVoidHook("browser_session_end", event, ctx);
+  }
+
+  async function runBeforeBrowserAction(
+    event: PluginHookBeforeBrowserActionEvent,
+    ctx: PluginHookBrowserContext,
+  ): Promise<PluginHookBeforeBrowserActionResult | undefined> {
+    return runModifyingHook<"before_browser_action", PluginHookBeforeBrowserActionResult>(
+      "before_browser_action",
+      event,
+      ctx,
+      { mergeResults: mergeBeforeBrowserAction },
+    );
+  }
+
+  async function runAfterBrowserAction(
+    event: PluginHookAfterBrowserActionEvent,
+    ctx: PluginHookBrowserContext,
+  ): Promise<void> {
+    await runVoidHook("after_browser_action", event, ctx);
+  }
+
