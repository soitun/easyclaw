From 8a0d93779957294dbbfeab2cff8d759f69051c35 Mon Sep 17 00:00:00 2001
From: RivonClaw CI <ci@rivonclaw.com>
Date: Fri, 10 Apr 2026 18:17:51 -0700
Subject: [PATCH 4/8] vendor(openclaw): skip stopChannel for new-account QR
 logins
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Why:
- OpenClaw's web.login.start handler unconditionally calls
  context.stopChannel(provider.id, accountId) before generating a QR
  code. When accountId is undefined (new account login), this stops ALL
  running accounts for the channel, killing live WeChat bots the moment
  the QR code is displayed — before anyone even scans it.
- EasyClaw supports multiple WeChat accounts. Starting a QR login for a
  new account must not disconnect existing accounts.

Removal:
- Drop when upstream OpenClaw makes stopChannel conditional on re-login
  vs new-account login, or adds an option to skip channel stop.

Tests:
- apps/desktop/src/gateway/vendor-web-login-no-stop.sentinel.test.ts
---
 src/gateway/server-methods/web.ts | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/src/gateway/server-methods/web.ts b/src/gateway/server-methods/web.ts
index 8f8df9582d..a9947f0b79 100644
--- a/src/gateway/server-methods/web.ts
+++ b/src/gateway/server-methods/web.ts
@@ -87,7 +87,9 @@ export const webHandlers: GatewayRequestHandlers = {
         channelId: provider.id,
         accountId,
       });
-      await context.stopChannel(provider.id, accountId);
+      if (accountId) {
+        await context.stopChannel(provider.id, accountId);
+      }
       const result = await provider.gateway.loginWithQrStart({
         force: Boolean((params as { force?: boolean }).force),
         timeoutMs:
-- 
