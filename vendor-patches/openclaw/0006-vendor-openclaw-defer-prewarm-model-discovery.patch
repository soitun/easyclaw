From 2fa64e8165e08af16fbf5e4610821e9ebc46ea03 Mon Sep 17 00:00:00 2001
From: RivonClaw CI <ci@rivonclaw.com>
Date: Tue, 7 Apr 2026 23:55:27 -0700
Subject: [PATCH] vendor(openclaw): defer prewarmConfiguredPrimaryModel to
 unblock event loop
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Why:
- prewarmConfiguredPrimaryModel() triggers resolveImplicitProviders() which
  serially discovers all 29 provider plugins (~250-500ms each = 12-25s total
  on Windows). Because resolvePluginProviders defaults cache:false, each of
  the 4 discovery orders reloads all plugins from disk.
- This blocks the event loop after gateway READY, causing WebSocket
  handshake timeouts and delaying the chat UI by 12-25s.
- The prewarm is purely a validation step — it pre-checks that the
  configured model resolves correctly. Deferring it has no functional
  impact; the model is still resolved on first actual agent use.

Removal:
- Drop when upstream fixes provider-discovery caching
  (https://github.com/openclaw/openclaw/issues/50370) or adds a config
  flag to skip startup provider discovery.

Tests:
- apps/desktop/src/gateway/__tests__/gateway-config-handlers.test.ts
---
 src/gateway/server-startup.ts | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/src/gateway/server-startup.ts b/src/gateway/server-startup.ts
index 6bc7a85a9d..d226e201a6 100644
--- a/src/gateway/server-startup.ts
+++ b/src/gateway/server-startup.ts
@@ -153,9 +153,17 @@ export async function startGatewaySidecars(params: {
     isTruthyEnvValue(process.env.OPENCLAW_SKIP_PROVIDERS);
   if (!skipChannels) {
     try {
-      await prewarmConfiguredPrimaryModel({
+      // Fire-and-forget: prewarm runs provider discovery which serially
+      // loads all provider plugins (~250-500ms each, 12-25s total on Windows).
+      // Awaiting it blocks the event loop and delays WebSocket connections.
+      // Deferring lets channels start and WS handshakes complete while
+      // provider discovery runs in the background.
+      // See: https://github.com/openclaw/openclaw/issues/50370
+      prewarmConfiguredPrimaryModel({
         cfg: params.cfg,
         log: params.log,
+      }).catch((err) => {
+        params.log.warn(`deferred model warmup failed: ${String(err)}`);
       });
       await params.startChannels();
     } catch (err) {
-- 
