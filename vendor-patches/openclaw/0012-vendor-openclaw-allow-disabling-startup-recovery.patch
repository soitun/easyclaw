From 9b0358d526ceef639512b1c683eada047ed51977 Mon Sep 17 00:00:00 2001
From: RivonClaw Vendor Replay <vendor-replay@rivonclaw.invalid>
Date: Wed, 6 May 2026 07:23:04 -0700
Subject: [PATCH] vendor(openclaw): allow disabling startup recovery

Why:
- RivonClaw receives customer-service retries from backend/Airflow rather than relying on local gateway replay.
- OpenClaw startup delivery recovery and interrupted-session recovery can overwhelm the single desktop gateway process when many customer-service deliveries are queued.

Removal:
- Drop when upstream OpenClaw exposes first-class config for startup recovery policies or makes startup recovery budgeted enough for RivonClaw customer-service workloads.

Tests:
- vendor/openclaw/src/gateway/server-runtime-services.test.ts
- apps/desktop/src/infra/proxy/proxy-manager.test.ts
---
 src/gateway/server-runtime-services.test.ts | 27 +++++++++++++++++++++
 src/gateway/server-runtime-services.ts      | 20 ++++++++++++++-
 src/gateway/server.impl.ts                  |  1 +
 3 files changed, 47 insertions(+), 1 deletion(-)

diff --git a/src/gateway/server-runtime-services.test.ts b/src/gateway/server-runtime-services.test.ts
index ef3204381f..1853432aaf 100644
--- a/src/gateway/server-runtime-services.test.ts
+++ b/src/gateway/server-runtime-services.test.ts
@@ -26,6 +26,8 @@ vi.mock("../infra/heartbeat-runner.js", () => ({
 
 vi.mock("../infra/env.js", () => ({
   isVitestRuntimeEnv: hoisted.isVitestRuntimeEnv,
+  isTruthyEnvValue: (value: unknown) =>
+    typeof value === "string" && ["1", "true", "yes", "on"].includes(value.trim().toLowerCase()),
 }));
 
 vi.mock("../infra/outbound/deliver.js", () => ({
@@ -194,6 +196,31 @@ describe("server-runtime-services", () => {
     );
   });
 
+  it("can disable startup delivery and session restart recovery by environment", async () => {
+    vi.useFakeTimers();
+    const cron = { start: vi.fn(async () => undefined) };
+
+    activateGatewayScheduledServices({
+      minimalTestGateway: false,
+      cfgAtStart: {} as never,
+      deps: {} as never,
+      sessionDeliveryRecoveryMaxEnqueuedAt: 123,
+      cron,
+      logCron: { error: vi.fn() },
+      log: createLog(),
+      env: {
+        OPENCLAW_DISABLE_OUTBOUND_DELIVERY_RECOVERY: "1",
+        OPENCLAW_DISABLE_SESSION_RESTART_RECOVERY: "1",
+      } as never,
+    });
+
+    await vi.advanceTimersByTimeAsync(1_250);
+    await vi.dynamicImportSettled();
+
+    expect(hoisted.recoverPendingDeliveries).not.toHaveBeenCalled();
+    expect(hoisted.recoverPendingRestartContinuationDeliveries).not.toHaveBeenCalled();
+  });
+
   it("keeps scheduled services disabled for minimal test gateways", () => {
     const cron = { start: vi.fn(async () => undefined) };
 
