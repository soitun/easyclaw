 src/gateway/server-runtime-services.ts        | 20 +++++++++-
 .../server-startup-post-attach.test.ts        | 37 +++++++++++++++++++
 src/gateway/server-startup-post-attach.ts     | 11 +++++-
 src/gateway/server.impl.ts                    |  1 +
 5 files changed, 94 insertions(+), 2 deletions(-)

