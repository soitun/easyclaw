@@ -873,6 +873,19 @@ export async function runEmbeddedAttempt(
       modelApi: params.model.api,
       model: params.model,
     });
+    {
+      const earlyHookRunner = getGlobalHookRunner();
+      if (earlyHookRunner?.hasHooks("before_tool_resolve")) {
